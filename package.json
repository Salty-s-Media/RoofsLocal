{
  "name": "mini-ecom",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm run dev:frontend\" \"pnpm run dev:backend\"",
    "dev:frontend": "next dev src/frontend",
    "dev:backend": "nodemon --watch src/backend --exec ts-node src/backend/server.ts",
    "build": "npx prisma generate && pnpm run build:backend && pnpm run build:frontend",
    "build:frontend": "next build src/frontend",
    "build:backend": "echo 'No build step for backend'",
    "start": "concurrently \"pnpm run start:frontend\" \"pnpm run start:backend\"",
    "start:frontend": "next start src/frontend",
    "start:backend": "ts-node src/backend/server.ts",
    "lint": "next lint src/frontend",
    "install:all": "pnpm install"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@stripe/react-stripe-js": "^2.7.0",
    "@stripe/stripe-js": "^3.3.0",
    "@vercel/postgres": "^0.8.0",
    "axios": "^1.6.8",
    "body-parser": "^1.20.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "lucide-react": "^0.376.0",
    "next": "14.2.3",
    "react": "^18",
    "react-dom": "^18",
    "react-email": "^2.1.1",
    "resend": "^3.2.0",
    "stripe": "^15.4.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.11",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "nodemon": "^3.1.0",
    "postcss": "^8",
    "prisma": "^5.13.0",
    "tailwindcss": "^3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
